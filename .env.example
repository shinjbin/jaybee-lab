POSTGRES_DB=news_digest
POSTGRES_USER=news_user
POSTGRES_PASSWORD=change-me

NEWS_POLL_INTERVAL_MINUTES=30
FMP_API_KEY=
FMP_BASE_URL=https://financialmodelingprep.com/stable
FMP_NEWS_PATH=/news/stock-latest
FMP_NEWS_LIMIT=12
FMP_NEWS_CATEGORY=market

KRX_API_KEY=
KRX_API_KEY_HEADER=AUTH_KEY
KRX_KOSPI_URL=
KRX_KOSPI_HISTORY_DAYS=30

TWELVE_DATA_API_KEY=
TWELVE_DATA_BASE_URL=https://api.twelvedata.com
TWELVE_DATA_HISTORY_DAYS=30
# QQQ/DIA/SPY are used as stable major-index proxies on the current Twelve Data plan.
TWELVE_DATA_SERIES=[{"symbol":"QQQ","displaySymbol":"NASDAQ","name":"Nasdaq 100","market":"US"},{"symbol":"DIA","displaySymbol":"DOW","name":"Dow Jones","market":"US"},{"symbol":"SPY","displaySymbol":"S&P 500","name":"S&P 500","market":"US"},{"symbol":"USD/KRW","displaySymbol":"USD/KRW","name":"USD to KRW","market":"FX"}]

NEWS_SUMMARY_BATCH_SIZE=10
BRIEFING_WINDOW_HOURS=48

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ENV=real
KIS_BASE_URL=
KIS_MARKET_FLOW_ENABLED=true
KIS_MARKET_CODE=0001
KIS_FLOW_TOP_COUNT=10
KIS_FLOW_COLLECTION_START_HOUR=8
KIS_FLOW_COLLECTION_END_HOUR=16
